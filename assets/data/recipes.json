---
layout: null
permalink: /assets/data/recipes.json
---

[
{%- assign recipes = site.pages | where: "layout", "recipe" -%}
{%- assign out = "" -%}

{%- for r in recipes -%}
  {%- if r.recipe_group and r.recipe_group != "" -%}
    {%- capture item -%}
{
  "title": {{ r.title | jsonify }},
  "recipe_title": {{ r.recipe_title | default: r.title | jsonify }},
  "recipe_subtitle": {{ r.recipe_subtitle | jsonify }},
  "recipe_group": {{ r.recipe_group | jsonify }},
  "recipe_sort": {{ r.recipe_sort | jsonify }},
  "recipe_tested": {{ r.recipe_tested | jsonify }},
  "url": {{ r.url | relative_url | jsonify }},

  "calories": {{ r.calories | jsonify }},
  "proteines": {{ r.proteines | jsonify }},
  "glucides_nets": {{ r.glucides_nets | jsonify }},

  "nutrition": {
    "lipides": {{ r.nutrition.lipides | jsonify }},
    "glucides": {{ r.nutrition.glucides | jsonify }},
    "fibres": {{ r.nutrition.fibres | jsonify }},
    "fructose": {{ r.nutrition.fructose | jsonify }}
  },

  "servings": {{ r.servings | jsonify }},
  "serving_size": {{ r.serving_size | jsonify }},

  "tags": {{ r.tags | jsonify }},
  "badges_nutritionnels": {{ r.badges_nutritionnels | jsonify }},

  "ingredients": {{ r.ingredients | jsonify }}
}
    {%- endcapture -%}

    {%- if out != "" -%}
      {%- assign out = out | append: "," -%}
    {%- endif -%}
    {%- assign out = out | append: item -%}
  {%- endif -%}
{%- endfor -%}

{{ out }}
]
